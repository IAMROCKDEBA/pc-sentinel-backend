# ============================================================
#  PC SENTINEL — Backend Environment Variables
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to version control.
# ============================================================

# --- Server ---
PORT=3001
NODE_ENV=production

# --- Security ---
# Secret key used to sign JWT tokens for the Dashboard login
JWT_SECRET=replace_with_a_long_random_secret_min_64_chars

# API key the PowerShell script sends with every heartbeat
HEARTBEAT_API_KEY=replace_with_another_long_random_secret

# Dashboard login credentials
DASHBOARD_USERNAME=admin
DASHBOARD_PASSWORD=replace_with_a_strong_password

# --- Telegram Bot ---
TELEGRAM_BOT_TOKEN=123456789:ABCDefGhIJKlmNoPQRsTUVwXyZ
TELEGRAM_CHAT_ID=987654321

# --- Heartbeat Config ---
# Seconds without a ping before the PC is marked Offline
OFFLINE_THRESHOLD_SECONDS=45
